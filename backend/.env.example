# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# Local development:
DATABASE_URL=postgresql://username:password@localhost:5432/competition_account

# Cloud providers (Railway, Heroku, AWS RDS) provide DATABASE_URL automatically
# Format: postgresql://user:password@host:port/database?sslmode=require
# Example Railway: postgresql://postgres:password@containers-us-west-123.railway.app:5432/railway
# Example Heroku: postgres://user:password@ec2-host.compute-1.amazonaws.com:5432/dbname

# Or use individual connection parameters:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=competition_account
# DB_USER=username
# DB_PASSWORD=password

# Authentication
# IMPORTANT: Generate a secure random string for production
# Example: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this-in-production

# CORS Configuration
# Development: Allow local origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Production: Set to your actual frontend domain(s)
# Example: CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# File Upload Limits (in bytes)
# Default: 10MB
MAX_FILE_SIZE=10485760

# Connection Pool Settings
# Adjust based on your database plan limits
DB_POOL_MIN=2
DB_POOL_MAX=10

# Test Database Configuration
# Separate database for running tests to avoid interfering with development data
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/competition_account_test
